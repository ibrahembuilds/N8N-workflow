    {
      "parameters": {
        "jsCode": "const subscriber = $input.item.json;\nconst today = new Date();\nconst dayOfWeek = today.getDay(); // 0=Sunday, 1=Monday, ..., 6=Saturday\nconst frequency = subscriber.Frequency || 'Daily';\nconst isActive = String(subscriber.Active).toUpperCase() === 'TRUE';\n\nif (!isActive) {\n  return [];\n}\n\n// Daily: send every day\n// Weekly: send every Monday (dayOfWeek === 1)\nif (frequency === 'Daily' || (frequency === 'Weekly' && dayOfWeek === 1)) {\n  return [{ json: subscriber }];\n}\n\nreturn [];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [620, 360],
      "id": "a1b2c3d4-0007-0007-0007-000000000007",
      "name": "Check Send Frequency"
    },
