    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an expert newsletter writer. Write a high-quality, engaging newsletter email for a subscriber.\n\nSubscriber Name: {{ $json.Name }}\nTopics of Interest: {{ $json.Topics }}\nEmail Frequency: {{ $json.Frequency }}\nToday's Date: {{ $now.format('dddd, MMMM D, YYYY') }}\n\nInstructions:\n1. First line must be: SUBJECT: [write a compelling, personalized subject line here]\n2. Then a blank line.\n3. Then write: BODY: \n4. Then write the full HTML email body.\n\nEmail requirements:\n- Address the subscriber by their first name\n- Provide 2-3 valuable, practical insights or tips on their topics\n- Include relevant news or trends if applicable\n- Keep it concise but informative (400-600 words in the body)\n- Use a warm, friendly and professional tone\n- Format with simple HTML (h2, p, ul, li tags are fine)\n- End with an encouraging closing message\n- Do NOT include unsubscribe links or footer boilerplate\n\nWrite the email now:"
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.5,
      "position": [880, 360],
      "id": "a1b2c3d4-0009-0009-0009-000000000009",
      "name": "Generate Newsletter Email"
    },
    {
      "parameters": {
        "jsCode": "const aiOutput = $input.item.json.text || '';\n\n// Extract SUBJECT line\nconst subjectMatch = aiOutput.match(/^SUBJECT:\\s*(.+?)(?:\\r?\\n|$)/im);\nconst subject = subjectMatch ? subjectMatch[1].trim() : 'Your Personalized Newsletter';\n\n// Extract BODY section\nconst bodyMatch = aiOutput.match(/BODY:\\s*([\\s\\S]+)/i);\nlet body = bodyMatch ? bodyMatch[1].trim() : aiOutput;\n\n// Wrap plain text in a styled HTML container if not already HTML\nif (!body.toLowerCase().includes('<html>')) {\n  body = `<html><body style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px; color: #333; line-height: 1.6;\">\n${body}\n<hr style=\"border: none; border-top: 1px solid #eee; margin: 30px 0;\">\n<p style=\"font-size: 12px; color: #999;\">You are receiving this because you subscribed to a personalized newsletter. Reply to unsubscribe.</p>\n</body></html>`;\n}\n\n// Get subscriber info from earlier node\nconst subscriber = $('Check Send Frequency').item.json;\n\nreturn [{\n  json: {\n    subscriberEmail: subscriber.Email,\n    subscriberName: subscriber.Name,\n    subject: subject,\n    body: body\n  }\n}];"
      },
